[debug] [2026-04-09T22:59:16.293Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/wc2026-40589/rulesets {"name":"projects/wc2026-40589/rulesets/4165d711-60fe-424b-9ada-2c6d525604ab","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // ── Helpers ───────────────────────────────────────────────\n    function isSignedIn() {\n      return request.auth != null;\n    }\n    function isOwner(uid) {\n      return isSignedIn() && request.auth.uid == uid;\n    }\n    function isAdmin() {\n      return isSignedIn() &&\n        exists(/databases/$(database)/documents/admins/$(request.auth.uid));\n    }\n\n    // ── Users ─────────────────────────────────────────────────\n    // Anyone signed in can create their own doc; only admins can set status/activeRounds.\n    match /users/{uid} {\n      allow read:   if isOwner(uid) || isAdmin();\n      allow create: if isOwner(uid);\n      allow update: if isAdmin()\n                    || (isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys()\n                        .hasAny(['status', 'activeRounds', 'approvedAt', 'approvedBy']));\n    }\n\n    // ── Admins ────────────────────────────────────────────────\n    // Read-only from the client; managed manually in Firebase Console.\n    match /admins/{uid} {\n      allow read:  if isAdmin();\n      allow write: if false;\n    }\n\n    // ── Predictions ───────────────────────────────────────────\n    // Active players can write their own predictions; reads locked to owner.\n    match /predictions/{docId} {\n      allow read:   if isSignedIn() && resource.data.uid == request.auth.uid;\n      allow create, update: if isSignedIn()\n                            && request.resource.data.uid == request.auth.uid\n                            && isActivePlayer();\n      allow delete: if false;\n    }\n\n    // ── Matches (results) ─────────────────────────────────────\n    // Everyone can read; only admins can write results.\n    match /matches/{matchId} {\n      allow read:  if true;\n      allow write: if isAdmin();\n    }\n\n    // ── Payments ──────────────────────────────────────────────\n    // Only the Cloud Function (admin SDK) writes payments.\n    // The owner can read their own payment records.\n    match /payments/{paymentId} {\n      allow read:  if isSignedIn() && resource.data.uid == request.auth.uid;\n      allow write: if false;  // Cloud Functions only (admin SDK bypasses rules)\n    }\n\n    // ── Helper: active player check ───────────────────────────\n    function isActivePlayer() {\n      return isSignedIn() &&\n        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-09T22:59:15.406116Z","metadata":{"services":["cloud.firestore"]}}
